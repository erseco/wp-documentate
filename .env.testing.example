# WordPress Test Suite Configuration
# Copy this file to .env.testing and adjust values as needed

# Path to WordPress test library (installed by bin/install-wp-tests.sh)
WP_TESTS_DIR=/tmp/wordpress-tests-lib

# Path to WordPress core installation
WP_DEVELOP_DIR=/tmp/wordpress

# Database configuration for tests
DB_NAME=wordpress_test
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost

# WordPress table prefix (optional)
WORDPRESS_TABLE_PREFIX=wp_
